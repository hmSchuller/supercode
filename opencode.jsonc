{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "lite",
  "small_model": "opencode-go/mimo-v2.5",
  "enabled_providers": ["opencode-go", "openai"],
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "lite": {
      "mode": "primary",
      "description": "Fast default — mimo v2.5",
      "prompt": "{file:./prompts/primary.txt}",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    },
    "standard": {
      "mode": "primary",
      "description": "Balanced — minimax m3",
      "prompt": "{file:./prompts/primary.txt}",
      "model": "opencode-go/minimax-m3",
      "variant": "thinking"
    },
    "pro": {
      "mode": "primary",
      "description": "Most capable — gpt-5.5",
      "prompt": "{file:./prompts/primary.txt}",
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    },
    "general": {
      "mode": "subagent"
    },
    "runner": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    }
  },
  "command": {
    "commit": {
      "template": "",
      "model": "opencode-go/mimo-v2.5"
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
