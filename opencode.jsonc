{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "default_agent": "lite",
  "small_model": "opencode-go/mimo-v2.5",
  "enabled_providers": ["opencode-go", "openai"],
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "lite": {
      "mode": "primary",
      "description": "Fast default agent",
      "prompt": "{file:./prompts/agents/primary.txt}",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high"
    },
    "standard": {
      "mode": "primary",
      "description": "Balanced agent",
      "prompt": "{file:./prompts/agents/primary.txt}",
      "model": "opencode-go/minimax-m3",
      "variant": "thinking"
    },
    "pro": {
      "mode": "all",
      "description": "Most capable agent",
      "prompt": "{file:./prompts/agents/primary.txt}",
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "permission": {
        "task": {
          "explore": "allow",
          "runner": "allow",
          "general": "allow"
        }
      }
    },
    "explore": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high",
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "general": {
      "mode": "subagent",
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "runner": {
      "mode": "subagent",
      "model": "opencode-go/mimo-v2.5",
      "variant": "high",
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    }
  },
  "command": {
    "commit": {
      "description": "Writes a commit message for the staged changes",
      "template": "{file:./prompts/command/commit.txt}",
      "agent": "runner",
      "subtask": true
    },
    "summon-pro": {
      "description": "Spawn a pro subagent for a focused task — pass what you need, e.g. /summon-pro Review this spec",
      "template": "{file:./prompts/command/summon-pro.txt}"
    }
  },
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"]
}
